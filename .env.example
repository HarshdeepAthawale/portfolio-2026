# Visitor counter (required on Vercel — file storage does not persist on serverless)
# Create a free Redis database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Spotify "Now Playing" (optional — without these, the card shows the static
# track in src/config/spotify.ts). Setup:
#   1. Create an app at https://developer.spotify.com/dashboard
#   2. Add redirect URI: http://127.0.0.1:8888/callback
#   3. Copy Client ID + Client Secret below
#   4. Run: node scripts/get-spotify-refresh-token.mjs  → paste the printed token
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
